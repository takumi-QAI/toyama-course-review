generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  name          String
  password      String
  reviews       Review[]
  textbooks     Textbook[]
  contributions CourseContribution[]
  reviewLikes   ReviewLike[]
  createdAt     DateTime             @default(now())
}

model Faculty {
  id      String   @id @default(cuid())
  name    String   @unique
  courses Course[]
}

model Course {
  id            String               @id @default(cuid())
  name          String
  instructor    String
  faculty       Faculty              @relation(fields: [facultyId], references: [id])
  facultyId     String
  year          Int
  semester      String
  credits       Int
  courseType    String
  syllabusCode  String?
  syllabusJscd  String?
  syllabusYear  Int?
  department    String?
  reviews       Review[]
  textbooks     Textbook[]
  contributions CourseContribution[]
  summary       String?
  summaryAt     DateTime?
  createdAt     DateTime             @default(now())

  @@index([facultyId])
  @@index([name])
}

model Review {
  id        String       @id @default(cuid())
  content   String
  easyScore Int
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  course    Course       @relation(fields: [courseId], references: [id])
  courseId  String
  likes     ReviewLike[]
  createdAt DateTime     @default(now())

  @@index([courseId])
}

model ReviewLike {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model Textbook {
  id          String   @id @default(cuid())
  title       String
  author      String?
  isbn        String?
  price       Int
  condition   String
  description String?
  imageUrl    String?
  status      String   @default("available")
  contact     String
  seller      User     @relation(fields: [sellerId], references: [id])
  sellerId    String
  course      Course   @relation(fields: [courseId], references: [id])
  courseId    String
  createdAt   DateTime @default(now())

  @@index([courseId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model CourseContribution {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  field     String
  value     String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([courseId])
  @@index([approved])
}

model RateLimit {
  id      String   @id @default(cuid())
  key     String
  count   Int      @default(1)
  resetAt DateTime

  @@index([key])
}
