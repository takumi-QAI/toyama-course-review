# PostgreSQL接続URL（Neonなどから取得）
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth設定
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="ランダムな文字列（openssl rand -base64 32 で生成）"

# 管理者メールアドレス（あなたのアカウントのメールアドレス）
ADMIN_EMAIL="your-email@example.com"
NEXT_PUBLIC_ADMIN_EMAIL="your-email@example.com"

# Groq API Key（https://console.groq.com で取得）
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google AdSense Publisher ID（審査通過後に設定）
# NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"

# シラバスクローラー用（必要な場合のみ）
# SYLLABUS_SESSION_COOKIE="your-session-cookie"
