# PostgreSQL接続URL（Neonなどから取得）
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth設定
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="ランダムな文字列（openssl rand -base64 32 で生成）"

# 管理者メールアドレス（あなたのアカウントのメールアドレス）
ADMIN_EMAIL="your-email@example.com"
NEXT_PUBLIC_ADMIN_EMAIL="your-email@example.com"

# Groq API Key（https://console.groq.com で取得）
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# Google AdSense 設定
# 1. https://adsense.google.com でサイトを申請・審査通過後に設定
# 2. NEXT_PUBLIC_ADSENSE_ID に Publisher ID を設定
# 3. 各スロット ID は AdSense 管理画面 → 広告ユニット から取得
# ============================================================

# Publisher ID（ca-pub-から始まる）
# NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"

# 広告スロット ID（10桁の数字）
# NEXT_PUBLIC_AD_SLOT_1="XXXXXXXXXX"   # 授業詳細ページ上部
# NEXT_PUBLIC_AD_SLOT_2="XXXXXXXXXX"   # 授業詳細ページ口コミ下
# NEXT_PUBLIC_AD_SLOT_3="XXXXXXXXXX"   # 授業一覧ページ
# NEXT_PUBLIC_AD_SLOT_4="XXXXXXXXXX"   # ホームページ
# NEXT_PUBLIC_AD_SLOT_5="XXXXXXXXXX"   # 教科書ページ

# Vercel Blob（教科書画像アップロード用）
# Vercel ダッシュボード → Storage → Blob で設定
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# NEXT_PUBLIC_BLOB_ENABLED="true"

# サイトURL（sitemap.xml / OGP に使用）
# NEXT_PUBLIC_SITE_URL="https://toyama-course-review.vercel.app"

# シラバスクローラー用（必要な場合のみ）
# SYLLABUS_SESSION_COOKIE="your-session-cookie"
